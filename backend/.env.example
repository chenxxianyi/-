# 知识型阅读工作台 - 后端环境变量配置
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=KnowledgeReader
ENV=development
DEBUG=true
API_PREFIX=/api
SECRET_KEY=replace_with_at_least_32_random_characters
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# MySQL 配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3310
MYSQL_USER=xxladmin
MYSQL_PASSWORD=XXLadmin_2021!
MYSQL_DATABASE=knowledge_reader

# Redis 配置
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-reader
MINIO_SECURE=false

# 上传限制（50MB）
MAX_UPLOAD_SIZE=52428800
